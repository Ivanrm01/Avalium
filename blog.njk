<link rel="stylesheet" href="/styles.css">
<style>
.featured { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); padding: 3rem 0; border-bottom: 1px solid var(--line-strong); align-items: center; }
@media (max-width: 760px) { .featured { grid-template-columns: 1fr; } }
.featured-visual { aspect-ratio: 4/3; background: linear-gradient(135deg, var(--navy), var(--navy-soft)); position: relative; display: flex; align-items: center; justify-content: center; padding: 3rem; }
.featured-visual::after { content: ''; position: absolute; inset: 12px; border: 1px solid rgba(184, 137, 92, 0.3); }
.featured-quote { font-family: var(--font-display); font-size: clamp(1.4rem, 2.2vw, 2.2rem); color: var(--cream); font-style: italic; text-align: center; line-height: 1.25; font-variation-settings: "opsz" 144, "SOFT" 100; font-weight: 300; }
.featured-tag { font-family: var(--font-display); font-style: italic; color: var(--terracotta); font-size: 0.95rem; margin-bottom: 1rem; display: inline-block; }
.featured h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); margin-bottom: 1.25rem; }
.filter-bar { display: flex; gap: 1.5rem; flex-wrap: wrap; padding: 1.5rem 0 2.5rem; border-bottom: 1px solid var(--line); margin-bottom: 3rem; }
.filter-bar button { font-family: var(--font-body); font-size: 0.85rem; color: var(--muted); padding: 0.4rem 0.85rem; transition: color 0.2s; border-radius: 2px; cursor: pointer; border: none; background: none; }
.filter-bar button.active, .filter-bar button:hover { color: var(--terracotta); background: var(--cream-deep); }
.card { transition: opacity 0.3s ease; }
.card.hidden { display: none; }
.empty-state { padding: 4rem 0; text-align: center; color: var(--muted); }
</style>
</head>
<body>

