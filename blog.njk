      <div class="footer-brand"><a href="/index.html" class="logo"><img src="/assets/logo-cream.png" alt="Avalium Consulting Group"></a><p>Soluciones de garantía inmobiliaria para deudas tributarias y operaciones societarias en sociedades limitadas.</p></div>
      <div><h5>Servicios</h5><ul><li><a href="/suspension-deudas-aeat.html">Suspensión AEAT</a></li><li><a href="/aplazamiento-fraccionamiento-aeat.html">Aplazamientos</a></li><li><a href="/ampliacion-capital-garantia-inmobiliaria.html">Ampliación de capital</a></li><li><a href="/hipoteca-unilateral.html">Hipoteca unilateral</a></li></ul></div>
      <div><h5>Empresa</h5><ul><li><a href="/sobre-nosotros.html">Sobre nosotros</a></li><li><a href="/equipo.html">Equipo</a></li><li><a href="/casos-de-exito.html">Casos de éxito</a></li><li><a href="/blog.html">Blog</a></li></ul></div>
      <div><h5>Contacto</h5><ul><li>Madrid · Castellón</li><li><a href="tel:+34900000000">+34 900 000 000</a></li><li><a href="mailto:contacto@avalium.es">contacto@avalium.es</a></li><li><a href="/contacto.html">Solicitar reunión</a></li></ul></div>
    </div>
    <div class="footer-bottom"><span>© 2026 Avalium Consulting Group, S.L.</span><div class="footer-bottom-links"><a href="/legal/aviso-legal.html">Aviso legal</a><a href="/legal/privacidad.html">Privacidad</a><a href="/legal/cookies.html">Cookies</a></div></div>
  </div>
</footer>

<script>
// Filtrado por categoría
const filterBtns = document.querySelectorAll('.filter-bar button');
const cards = document.querySelectorAll('#posts-grid .card');

filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    const filter = btn.dataset.filter;
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    cards.forEach(card => {
      if (filter === 'all' || card.dataset.category === filter) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  });
});

// Animación reveal al hacer scroll
const reveals = document.querySelectorAll('.reveal');
if (reveals.length) {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
  reveals.forEach(el => observer.observe(el));
}
</script>
<script src="/assets/menu.js"></script>
</body>
</html>
