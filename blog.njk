    <button class="menu-toggle" aria-label="Menú"><span></span><span></span><span></span></button>
  </div>
</header>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/index.html">Inicio</a><span>/</span><span>Blog</span></div>
    <div class="page-hero-grid">
      <div class="reveal">
        <span class="eyebrow">— BLOG TRIBUTARIO</span>
        <h1 style="margin-top: 1.25rem;">Notas técnicas sobre <em>derecho tributario</em> aplicado.</h1>
      </div>
      <div class="reveal reveal-delay-1">
        <p class="lede">Análisis prácticos, no académicos. Cada artículo nace de un caso real, una duda repetida o un cambio normativo que afecta a empresas con patrimonio inmobiliario y exposición fiscal.</p>
      </div>
    </div>
  </div>
</section>

<section class="section-sm">
  <div class="container">

    {# Buscar artículo destacado: el primero con featured=true, o el más reciente si ninguno está marcado #}
    {%- set featuredPost = collections.posts | featuredPost -%}

    {%- if featuredPost -%}
    <article class="featured reveal">
      <a href="{{ featuredPost.url }}" class="featured-visual">
        {%- if featuredPost.data.featured_quote -%}
        <p class="featured-quote">{{ featuredPost.data.featured_quote | safe }}</p>
        {%- else -%}
        <p class="featured-quote">"{{ featuredPost.data.title }}"</p>
        {%- endif -%}
      </a>
      <div>
        <span class="featured-tag">— Destacado · {{ featuredPost.data.tag }}</span>
        <h2><a href="{{ featuredPost.url }}">{{ featuredPost.data.title }}</a></h2>
        <p style="color: var(--navy-soft); margin-bottom: 1.5rem;">{{ featuredPost.data.summary or featuredPost.data.lede | striptags }}</p>
        <div style="display: flex; gap: 1.5rem; font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem;">
          <span>Equipo Avalium</span><span>·</span><span>{{ featuredPost.data.reading_time }} lectura</span><span>·</span><span>{{ featuredPost.data.date | dateFormat }}</span>
        </div>
        <a href="{{ featuredPost.url }}" class="btn btn-ghost">Leer artículo <span class="arrow">→</span></a>
      </div>
    </article>
    {%- endif -%}

    {# Calcular categorías únicas para el filtro #}
    {%- set tags = collections.posts | uniqueTags -%}

    <div class="filter-bar reveal">
      <button class="active" data-filter="all">Todos</button>
      {%- for tag in tags -%}
      <button data-filter="{{ tag }}">{{ tag }}</button>
      {%- endfor -%}
    </div>

    {%- if collections.posts.length == 0 -%}
    <div class="empty-state">
      <p>Aún no hay artículos publicados.</p>
    </div>
    {%- else -%}
    <div class="cards-grid" id="posts-grid">
      {%- for post in collections.posts | withoutFeatured -%}
        <a href="{{ post.url }}" class="card reveal" data-category="{{ post.data.tag }}">
          <span class="card-tag">— {{ post.data.tag }}</span>
          <h3>{{ post.data.title }}</h3>
          <p>{{ post.data.summary or post.data.lede | striptags | truncate(160) }}</p>
          <div class="card-meta"><span>{{ post.data.reading_time }}</span><span>{{ post.data.date | dateFormat }}</span></div>
        </a>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <div style="margin-top: 4rem; text-align: center;" class="reveal">
      <p style="color: var(--muted); font-size: 0.9rem; margin-bottom: 1.25rem;">¿Quieres recibir el próximo análisis directamente en tu email?</p>
      <a href="/contacto.html" class="btn btn-ghost">Suscribirse a la newsletter <span class="arrow">→</span></a>
    </div>

  </div>
</section>

